generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      UserRole @default(CONTROL_OWNER)
  department String?
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approvals          ApprovalWorkflow[] @relation("Approver")
  requestedApprovals ApprovalWorkflow[] @relation("Requester")
  ownedControls      MaterialControl[]
  ownedRisks         Risk[]
  ownedIssues        Issue[]
  comments           Comment[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  assignedControls   ControlAssignment[]
  createdVersions    Version[]
}

enum UserRole {
  SYSTEM_ADMIN
  FRAMEWORK_OWNER
  CONTROLS_MANAGER
  CONTROL_OWNER
  REVIEWER
  BOARD_MEMBER
}

// New Effectiveness Criteria Framework Models
model EffectivenessCriteriaConfig {
  id                String   @id @default(uuid())
  companyId         String   @default("default")
  version           String   @default("1.0")
  pathway           String   // "guided" or "custom"
  
  // Company Profile (JSON)
  companyProfile    String   // JSON: stage, ownership, regulatory, priorities, maturity, riskAppetite, size
  
  // The 7 Criteria Configurations (JSON)
  criteriaConfig    String   // JSON: riskIdentification, frameworkDesign, controlOperating, issueResponsiveness, riskOutcome, governance, continuousImprovement
  
  // Overall Target
  overallTarget     Int      @default(85)
  
  // Approval
  boardApproved     Boolean  @default(false)
  approvedBy        String?
  approvedDate      DateTime?
  
  // Version tracking
  active            Boolean  @default(true)
  supersedesId      String?  // Previous version
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([companyId, active])
}

// Legacy model - keeping for backward compatibility during migration
model EffectivenessCriteria {
  id            String   @id @default(uuid())
  dimension     String
  criteria      String
  threshold     String
  evidenceType  String
  frequency     String
  status        String
  categorization String  @default("B") // B (Baseline), H (High), C (Critical)
  approvedBy    String?
  approvedDate  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FrameworkComponent {
  id           String   @id @default(uuid())
  type         String
  name         String
  description  String
  owner        String
  status       String
  lastReviewed DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MaterialControl {
  id                String   @id @default(uuid())
  name              String
  description       String
  materialityScore  Int
  rationale         String
  owner             String
  ownerId           String?
  evidenceSource    String
  testingFrequency  String
  dependencies      String
  effectiveness     String
  lastTested        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userOwner    User?       @relation(fields: [ownerId], references: [id])
  testPlans    TestPlan[]
  issues       Issue[]
}

model Risk {
  id               String   @id @default(uuid())
  title            String
  description      String
  category         String
  inherentRisk     String
  residualRisk     String
  owner            String
  ownerId          String?
  linkedObjectives String
  linkedControls   String
  lastAssessed     DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userOwner User? @relation(fields: [ownerId], references: [id])
}

model Control {
  id             String   @id @default(uuid())
  name           String
  description    String
  type           String
  automation     String
  frequency      String
  owner          String
  linkedRisks    String
  effectiveness  String
  evidenceSource String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TestPlan {
  id                  String   @id @default(uuid())
  controlId           String
  controlName         String
  testType            String
  tester              String
  scheduledDate       DateTime
  status              String
  results             String?
  exceptions          String?
  remediationRequired Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  control MaterialControl @relation(fields: [controlId], references: [id])
}

model Issue {
  id              String   @id @default(uuid())
  title           String
  description     String
  severity        String
  controlId       String
  discoveredDate  DateTime
  status          String
  owner           String
  ownerId         String?
  dueDate         DateTime
  remediationPlan String?
  retestDate      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  control   MaterialControl @relation(fields: [controlId], references: [id])
  userOwner User?           @relation(fields: [ownerId], references: [id])
}

model IntegrationStatus {
  id               String   @id @default(uuid())
  system           String   @unique
  type             String   // erp, identity, ticketing, database, cloud, custom
  status           String   // connected, disconnected, error
  endpoint         String
  apiKey           String?
  authMethod       String?  // api_key, oauth, basic, token
  syncFrequency    String?  // realtime, 5min, 15min, 1hour, daily
  config           String?  // JSON: additional configuration
  lastSync         DateTime
  signalsReceived  Int      @default(0)
  exceptionsRaised Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  signals          IntegrationSignal[]
  exceptions       IntegrationException[]
}

model ControlGap {
  id               String   @id @default(uuid())
  source           String
  title            String
  description      String
  affectedControls String
  riskTheme        String
  priority         String
  proposedAction   String
  status           String
  identifiedDate   DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ApprovalWorkflow {
  id              String   @id @default(uuid())
  itemType        String
  itemId          String
  itemName        String
  requesterId     String
  currentApproverId String
  status          String
  submittedDate   DateTime
  comments        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requester       User @relation("Requester", fields: [requesterId], references: [id])
  currentApprover User @relation("Approver", fields: [currentApproverId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  userEmail String
  userName  String
  action    String   // CREATED, EDITED, DELETED, APPROVED, REJECTED, SUBMITTED, LOCKED, etc.
  entity    String   // Risk, Control, Assessment, etc.
  entityId  String
  field     String?  // Specific field changed
  oldValue  String?  // Previous value
  newValue  String?  // New value
  changes   String?  // JSON of all changes
  ipAddress String?
  timestamp DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([entity, entityId])
  @@index([timestamp])
}

// Principal Risks and Material Controls Workflow Models

model PrincipalRisk {
  id                String   @id @default(uuid())
  riskTitle         String
  riskStatement     String
  domainTags        String   // JSON array: ops/reporting/financial/compliance
  threatLensTags    String   // JSON array: business_model/performance/solvency/liquidity
  riskOwner         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  riskProcessLinks  RiskProcessLink[]
  gaps              Gap[]
  riskControlLinks  RiskControlLink[]
}

model Process {
  id                String   @id @default(uuid())
  processName       String
  processScope      String   // BU / entity / geography
  systemsInScope    String?  // JSON array
  processOwner      String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  riskProcessLinks  RiskProcessLink[]
  maturityAssessments ProcessMaturityAssessment[]
  asIsControls      AsIsControl[]
  gaps              Gap[]
  toBeControls      ToBeControl[]
}

model RiskProcessLink {
  id          String   @id @default(uuid())
  riskId      String
  processId   String
  relevance   String   // primary / secondary
  rationale   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  risk        PrincipalRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)
  process     Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@unique([riskId, processId])
}

model ProcessMaturityAssessment {
  id                String   @id @default(uuid())
  processId         String
  assessmentVersion Int      @default(1)
  assessmentDate    DateTime @default(now())
  answers           String   // JSON key-value pairs
  maturityProfile   String   // derived classification
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  process     Process @relation(fields: [processId], references: [id], onDelete: Cascade)
}

model StandardControl {
  id                String   @id @default(uuid())
  controlName       String
  controlObjective  String
  controlType       String   // preventive / detective / corrective
  domainTag         String   // ops / reporting / financial / compliance
  typicalFrequency  String
  typicalEvidence   String
  applicabilityRules String? // JSON conditions
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  asIsControls AsIsControl[]
  gaps         Gap[]
}

model AsIsControl {
  id                  String   @id @default(uuid())
  processId           String
  controlName         String
  controlObjective    String
  controlType         String   // preventive / detective / corrective
  domainTag           String
  frequency           String
  evidenceSource      String?
  owner               String?
  status              String   // exists / partial / not_exist
  mappedStdControlId  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  process           Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  mappedStdControl  StandardControl? @relation(fields: [mappedStdControlId], references: [id])
  riskControlLinks  RiskControlLink[]
}

model Gap {
  id                    String   @id @default(uuid())
  processId             String
  riskId                String?
  stdControlId          String?
  gapType               String   // missing / weak_design / weak_operation / no_owner / no_evidence
  recommendedToBeControlId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  process         Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  risk            PrincipalRisk? @relation(fields: [riskId], references: [id], onDelete: Cascade)
  stdControl      StandardControl? @relation(fields: [stdControlId], references: [id])
  toBeControl     ToBeControl? @relation(fields: [recommendedToBeControlId], references: [id])
}

model ToBeControl {
  id                    String   @id @default(uuid())
  processId             String
  controlObjective      String
  ownerRole             String?
  frequency             String
  evidenceType          String
  controlType           String   // preventive / detective / corrective
  domainTag             String
  implementationGuidance String?
  targetDate            DateTime?
  implementationStatus  String   @default("planned") // planned / in_progress / live
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  process           Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  gaps              Gap[]
  riskControlLinks  RiskControlLink[]
}

model RiskControlLink {
  id              String   @id @default(uuid())
  riskId          String
  asIsControlId   String?
  toBeControlId   String?
  controlSource   String   // as_is / to_be
  linkType        String   // mitigates / detects / corrects
  isMaterial      Boolean  @default(false)
  rationale       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  risk            PrincipalRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)
  asIsControl     AsIsControl? @relation(fields: [asIsControlId], references: [id], map: "RiskControlLink_asIsControl_fkey")
  toBeControl     ToBeControl? @relation(fields: [toBeControlId], references: [id], map: "RiskControlLink_toBeControl_fkey")

  @@unique([riskId, asIsControlId, toBeControlId, controlSource])
}

model FrameworkDocument {
  id              String   @id @default(uuid())
  title           String
  version         String   @default("1.0")
  sections        String   // JSON structure of all sections
  boardSummary    String?
  approvalStatus  String   @default("draft")
  approvedBy      String?
  approvedDate    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Section 2: Material Controls Mapping - Maturity Spectrum Models

model MaturitySelection {
  id                   String   @id @default(uuid())
  riskId               String
  selectedLevel        Int      // 1-4
  targetLevel          Int      // 1-4
  currentMaturityScore Float
  targetMaturityScore  Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([riskId])
}

model Section2Control {
  id                    String   @id @default(uuid())
  riskId                String
  title                 String
  description           String
  controlType           String   // preventive / detective / corrective
  objectives            String   // JSON array
  owner                 String
  reviewer              String?
  frequency             String
  evidence              String
  evidenceLocation      String?
  status                String   // existing / to_be_enhanced / planned / implemented / rejected
  maturityLevel         Int
  source                String   // existing_documented / ai_suggested / user_created
  templateId            String?
  implementationPhase   Int?
  implementationEffort  String?  // low / medium / high
  implementationTimeline String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  implementedAt         DateTime?
}

model Section2GapAnalysis {
  id                String   @id @default(uuid())
  riskId            String
  currentLevel      Int
  targetLevel       Int
  currentScore      Float
  targetScore       Float
  missingControls   String   // JSON array of template IDs
  suggestedControls String   // JSON array of SuggestedControl objects
  gapCount          Int
  effortEstimate    String   // low / medium / high
  timelineEstimate  String
  createdAt         DateTime @default(now())

  @@unique([riskId])
}

model Section2ImplementationPlan {
  id                     String   @id @default(uuid())
  riskId                 String?
  totalControls          Int
  existingControls       Int
  newControls            Int
  currentAverageMaturity Float
  targetAverageMaturity  Float
  phases                 String   // JSON array of ImplementationPhase objects
  totalTimelineMonths    Int
  createdAt              DateTime @default(now())
}

model Section2RiskCompletion {
  id            String   @id @default(uuid())
  riskId        String   @unique
  riskTitle     String
  status        String   // complete / in_progress
  currentLevel  Int
  targetLevel   Int
  controlCount  Int
  currentScore  Float
  targetScore   Float
  completedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Workflow State Management Models

model WorkflowState {
  id            String   @id @default(uuid())
  entityType    String   // Section0, Section1, Section2, Section3, Risk, Control
  entityId      String
  status        WorkflowStatus @default(DRAFT)
  submittedBy   String?
  submittedAt   DateTime?
  reviewedBy    String?
  reviewedAt    DateTime?
  approvedBy    String?
  approvedAt    DateTime?
  lockedBy      String?
  lockedAt      DateTime?
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([entityType, entityId])
  @@index([status])
}

enum WorkflowStatus {
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  BOARD_APPROVED
  LOCKED
  ARCHIVED
}

// Comments and Collaboration

model Comment {
  id            String   @id @default(uuid())
  entityType    String   // Risk, Control, Assessment, etc.
  entityId      String
  userId        String
  content       String
  parentId      String?  // For threaded replies
  status        CommentStatus @default(OPEN)
  resolvedBy    String?
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user          User     @relation(fields: [userId], references: [id])
  parent        Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies       Comment[] @relation("CommentReplies")
  
  @@index([entityType, entityId])
  @@index([userId])
}

enum CommentStatus {
  OPEN
  RESOLVED
  REOPENED
}

// Notifications System

model Notification {
  id            String   @id @default(uuid())
  userId        String
  type          NotificationType
  title         String
  message       String
  entityType    String?
  entityId      String?
  actionUrl     String?
  read          Boolean  @default(false)
  emailSent     Boolean  @default(false)
  createdAt     DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id])
  
  @@index([userId, read])
  @@index([createdAt])
}

enum NotificationType {
  CONTROL_ASSIGNED
  TESTING_ASSIGNED
  REVIEW_REQUESTED
  CHANGES_REQUESTED
  APPROVAL_GRANTED
  DEADLINE_APPROACHING
  DEADLINE_MISSED
  COMMENT_ADDED
  COMMENT_RESOLVED
  EVIDENCE_UPLOADED
  DEFICIENCY_ASSIGNED
  REMEDIATION_DUE
  BOARD_APPROVAL_REQUIRED
}

// Version Control System

model Version {
  id            String   @id @default(uuid())
  entityType    String   // Risk, Control, EffectivenessCriteria, etc.
  entityId      String
  versionNumber Int
  data          String   // JSON snapshot of the entity
  changes       String?  // Description of changes
  createdBy     String
  createdAt     DateTime @default(now())
  
  user          User     @relation(fields: [createdBy], references: [id])
  
  @@unique([entityType, entityId, versionNumber])
  @@index([entityType, entityId])
}

// Control Assignment and Testing

model ControlAssignment {
  id            String   @id @default(uuid())
  controlId     String
  userId        String
  assignedBy    String
  role          AssignmentRole
  status        AssignmentStatus @default(ASSIGNED)
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user          User     @relation(fields: [userId], references: [id])
  
  @@index([userId, status])
  @@index([controlId])
}

enum AssignmentRole {
  DOCUMENTER
  TESTER
  REVIEWER
  APPROVER
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

// Section 3: Control Testing (5 Effectiveness Tests)

model ControlTestingResult {
  id                    String   @id @default(uuid())
  controlId             String
  assessmentPeriod      String   // e.g., "2025"
  testerId              String
  testerName            String
  dueDate               DateTime?
  
  // Test 1: Design Effectiveness
  designEffective       Boolean?
  designQuestions       String?  // JSON array of question responses
  designNotes           String?
  designScore           Int?     // 0-5
  
  // Test 2: Operating Effectiveness
  operatingEffective    Boolean?
  operatingRate         Float?   // Percentage
  instancesTested       Int?
  instancesPassed       Int?
  instanceDetails       String?  // JSON array of instance test results
  operatingNotes        String?
  operatingScore        Int?     // 0-5
  
  // Test 3: Evidence Effectiveness
  evidenceEffective     Boolean?
  evidenceQuestions     String?  // JSON array of question responses
  evidenceNotes         String?
  evidenceScore         Int?     // 0-5
  
  // Test 4: Responsiveness Effectiveness
  responsivenessEffective Boolean?
  issuesIdentified      Int?
  issuesActioned        Int?
  responsivenessDetails String?  // JSON array of issue reviews
  responsivenessNotes   String?
  responsivenessScore   Int?     // 0-5
  
  // Test 5: Competence Effectiveness
  competenceEffective   Boolean?
  competenceQuestions   String?  // JSON array of question responses
  competenceNotes       String?
  competenceScore       Int?     // 0-5
  
  // Overall Rating
  overallRating         ControlEffectiveness?
  totalScore            Int?     // Sum of all scores
  rationale             String?
  
  // Evidence
  evidenceFiles         String?  // JSON array of file references
  
  // Workflow
  status                TestingStatus @default(NOT_STARTED)
  submittedAt           DateTime?
  reviewedBy            String?
  reviewedAt            DateTime?
  reviewComments        String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([controlId, assessmentPeriod])
  @@index([testerId])
  @@index([status])
}

enum ControlEffectiveness {
  EFFECTIVE
  PARTIALLY_EFFECTIVE
  INEFFECTIVE
}

enum TestingStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  FLAGGED_AS_DEFICIENCY
}

// Section 3: Framework Assessment (4-Layer Assessment)

model FrameworkAssessment {
  id                String   @id @default(uuid())
  riskId            String
  assessmentPeriod  String   // e.g., "2025"
  
  // Layer 1: Risk Trending
  priorYearScore    Int?
  currentYearScore  Int?
  trendEvidence     String?  // JSON
  
  // Layer 2: Incidents
  incidentsOccurred Boolean  @default(false)
  incidentCount     Int      @default(0)
  incidentDetails   String?  // JSON
  nearMisses        String?  // JSON
  
  // Layer 3: Leading Indicators
  indicatorData     String?  // JSON: 12-month trend
  percentToTarget   Float?
  
  // Layer 4: Objectives
  objectives        String?  // JSON: actual vs target
  achievementPercent Float?
  
  overallScore      Int?
  status            String   @default("draft")
  completedBy       String?
  completedAt       DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([riskId, assessmentPeriod])
}

// Section 3: Deficiency Management

model Deficiency {
  id                String   @id @default(uuid())
  controlId         String?
  riskId            String?
  type              DeficiencyType
  severity          DeficiencySeverity
  title             String
  description       String
  rootCause         String?
  identifiedDate    DateTime @default(now())
  identifiedBy      String
  
  // Remediation
  remediationPlan   String?
  responsibleOwner  String?
  targetDate        DateTime?
  verificationMethod String?
  
  status            DeficiencyStatus @default(IDENTIFIED)
  closedDate        DateTime?
  closedBy          String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([status])
  @@index([severity])
}

enum DeficiencyType {
  CONTROL_DESIGN
  CONTROL_OPERATING
  CONTROL_EVIDENCE
  CONTROL_RESPONSIVENESS
  CONTROL_COMPETENCE
  FRAMEWORK_INCIDENT
  OBJECTIVE_MISSED
}

enum DeficiencySeverity {
  SIGNIFICANT
  MINOR
}

enum DeficiencyStatus {
  IDENTIFIED
  REMEDIATION_PLANNED
  IN_REMEDIATION
  PENDING_VERIFICATION
  CLOSED
}

// Board Reporting

model BoardDeclaration {
  id                String   @id @default(uuid())
  assessmentPeriod  String
  declarationType   DeclarationType
  effectivenessScore Float?
  deficiencyCount   Int      @default(0)
  significantDeficiencies String? // JSON
  boardMinutes      String?  // File reference
  declaredBy        String
  declaredDate      DateTime
  
  createdAt         DateTime @default(now())
  
  @@unique([assessmentPeriod])
}

enum DeclarationType {
  CLEAN
  WITH_DISCLOSED_DEFICIENCIES
  QUALIFIED_MATERIAL_WEAKNESS
}

// System Integrations - Signals and Exceptions

model IntegrationSignal {
  id              String   @id @default(uuid())
  integrationId   String
  controlId       String
  eventType       String
  timestamp       DateTime
  data            String   // JSON: raw event data
  metadata        String?  // JSON: processed metadata
  processed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  
  integration     IntegrationStatus @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  @@index([integrationId, timestamp])
  @@index([controlId])
}

model IntegrationException {
  id              String   @id @default(uuid())
  integrationId   String
  controlId       String
  severity        String   // low, medium, high, critical
  message         String
  details         String
  timestamp       DateTime
  data            String?  // JSON: additional data
  status          String   @default("open") // open, investigating, resolved, closed
  assignedTo      String?
  resolvedAt      DateTime?
  resolvedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  integration     IntegrationStatus @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  @@index([integrationId, status])
  @@index([controlId])
  @@index([severity])
}
